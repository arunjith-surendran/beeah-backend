    {
      "name": "Create New Account",
      "item": [
        {
          "name": "Create New Account - Company (UAE/International Agency)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/create-new-account/add",
            "description": "Submits a new company agency onboarding application (onboarding + bank + documents). Public endpoint (no auth) as part of the onboarding flow. Exactly one of onboarding/personalDetails must be present.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"onboarding\": {\n    \"subType\": \"UAE Agency\",\n    \"agencyName\": \"Example Realty\",\n    \"email\": \"agency@example.com\",\n    \"phone\": \"+971501234567\",\n    \"type\": \"Agency\",\n    \"role\": \"Broker\",\n    \"poBox\": \"12345\",\n    \"ownerShipType\": \"LLC\",\n    \"companyReraRegistrationNumber\": \"RERA-12345\",\n    \"companyReraExpiry\": \"2027-01-01\",\n    \"authorizedWith\": \"Signatory\",\n    \"haveTrn\": \"100123456700003\",\n    \"authorizedSignatoryEmail\": \"signatory@example.com\",\n    \"authorizedSignatoryMobile\": \"501234568\",\n    \"authorizedSignatoryCountryCode\": \"+971\",\n    \"addressLine1\": \"123 Sheikh Zayed Road\",\n    \"addressLine2\": \"\",\n    \"city\": \"Dubai\",\n    \"country\": \"United Arab Emirates\",\n    \"tradeLicenseNumber\": \"TL-12345\",\n    \"tradeLicenseExpiry\": \"2027-01-01\"\n  },\n  \"bank\": {\n    \"bankName\": \"Emirates NBD\",\n    \"bankAccountName\": \"Example Realty\",\n    \"bankAccountNumber\": \"1234567890\",\n    \"beneficiaryName\": \"Example Realty\",\n    \"ibanNumber\": \"AE123456789012345678901\",\n    \"swiftCode\": \"EBILAEAD\",\n    \"currencyValue\": \"AED\",\n    \"bankBranchName\": \"Downtown Dubai Branch\",\n    \"bankAddress\": \"Sheikh Zayed Road, Dubai\"\n  },\n  \"documents\": [\n    {\n      \"documentType\": \"Trade License\",\n      \"fileName\": \"trade_license.pdf\",\n      \"base64Data\": \"<base64-encoded-file-content>\",\n      \"issueDate\": \"2022-01-01\",\n      \"expiryDate\": \"2027-01-01\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "noauth"
            }
          },
          "response": []
        },
        {
          "name": "Create New Account - Individual (Self-Licensed)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/create-new-account/add",
            "description": "Submits a new individual (self-licensed) agency onboarding application (personalDetails + bankInfo + optional licensePartners + documents). Public endpoint (no auth) as part of the onboarding flow. Exactly one of onboarding/personalDetails must be present. Note: personalDetails.countryCode and personalDetails.nationality map to Salesforce restricted picklists - countryCode must be \"Country: dialCode\" (e.g. \"United Arab Emirates: 971\", not \"971\"), and nationality must be the demonym (e.g. \"Indian\", not \"India\").",
