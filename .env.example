DATABASE_URL="postgresql://postgres:postgres@localhost:5432/beeah_broker?schema=public"

PORT=3000

# Comma-separated list of allowed origins for CORS, e.g. https://app.example.com,https://admin.example.com
CORS_ORIGIN="change-me"

JWT_ACCESS_SECRET="change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-too"
JWT_REFRESH_EXPIRES_IN="7d"

# Salesforce (OAuth2 client credentials flow)
# SALESFORCE_LOGIN_URL is your org's My Domain, e.g.
# https://beeahgroup--beeahdev.sandbox.my.salesforce.com
SALESFORCE_LOGIN_URL="change-me"
SALESFORCE_CLIENT_ID="change-me"
SALESFORCE_CLIENT_SECRET="change-me"
SALESFORCE_API_VERSION="v60.0"

# N-Genius (Network International) - Portal -> Settings -> Integrations -> Service Account
NGENIUS_API_KEY="change-me"
# Portal -> Organisational Hierarchy -> Outlet -> Reference
NGENIUS_OUTLET_ID="change-me"
# "ni" for sandbox, "networkinternational" for production
NGENIUS_REALM="ni"
NGENIUS_BASE_URL="https://api-gateway.sandbox.ngenius-payments.com"
# Where N-Genius redirects after payment - must be reachable, the app's WebView
# intercepts navigation to it before it actually loads.
NGENIUS_REDIRECT_URL="https://your-backend-host/payments/ngenius/callback"
