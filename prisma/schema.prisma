// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(uuid())
  firstName            String    @map("first_name")
  lastName             String    @map("last_name")
  email                String    @unique
  phone                String    @unique
  password             String?
  isAdmin              Boolean?  @default(false) @map("is_admin")
  status               String?
  role                 String?
  isActive             Boolean?  @default(true) @map("is_active")
  agencyId             String?   @map("agency_id")
  agencyName           String?   @map("agency_name")
  commissionVisibility Boolean?  @default(true) @map("commission_visibility")
  brnId                String?   @map("brn_id")
  onboardId            String?   @map("onboard_id")
  refreshToken         String?   @map("refresh_token")
  createdAt            DateTime? @default(now()) @map("created_at")
  updatedAt            DateTime? @updatedAt @map("updated_at")

  @@map("users")
}

model SalesforceToken {
  id               String   @id @default("salesforce")
  accessToken      String
  instanceUrl      String
  salesforceUserId String?  @map("salesforce_user_id")
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("salesforce_tokens")
}

// Card (N-Genius) payment attempts against an EOI. Manual (Bank Transfer/
// Cheque/Cash) payments are recorded in Salesforce only, not stored here at
// all - our backend only stores card payment details. Owned/queried
// exclusively by `eoiPayment` (`EoiCardPaymentRepository`); the reusable
// `paymentGateway` module never touches Prisma directly, so it doesn't know
// EOI or Sales Booking payments are stored in separate tables.
model EoiCardPayment {
  id                     String    @id @default(uuid())
  eoiId                  String    @map("eoi_id")
  amount                 Decimal
  currency               String
  // N-Genius order state: CREATED/CAPTURED/FAILED/... (mirrors N-Genius's
  // own vocabulary, not Salesforce's).
  status                 String    @default("CREATED")
  orderReference         String    @unique @map("order_reference")
  merchantOrderReference String    @map("merchant_order_reference")
  // Caller-supplied dedup key: a retried createOrder call with the same key
  // returns the existing order instead of creating a second one at N-Genius.
  // Nullable only because rows created before this column existed have none.
  idempotencyKey         String?   @unique @map("idempotency_key")
  gatewayResponse        Json?     @map("gateway_response")
  // Set once the deposit is recorded as a "Credit Card" mode-of-payment
  // entry in Salesforce - recordedAt staying null is what lets a failed
  // recording attempt retry on the next status poll.
  salesforceRecordId     String?   @map("salesforce_record_id")
  errorMessage           String?   @map("error_message")
  recordedAt             DateTime? @map("recorded_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@index([eoiId])
  @@map("eoi_card_payments")
}

// Card (N-Genius) payment attempts, not tied to any specific booking record -
// mirrors `EoiCardPayment`'s mechanics, one table per feature rather than a
// shared generic one, kept in sync with `salesBookingPayment`
// (`SalesBookingCardPaymentRepository`). `salesforceRecordId`/`recordedAt`
// stay unset for now since there's no Salesforce endpoint yet to record a
// booking payment against - see SalesBookingPaymentService.recordDeposit.
model SalesBookingCardPayment {
  id                     String    @id @default(uuid())
  amount                 Decimal
  currency               String
  status                 String    @default("CREATED")
  orderReference         String    @unique @map("order_reference")
  merchantOrderReference String    @map("merchant_order_reference")
  idempotencyKey         String?   @unique @map("idempotency_key")
  gatewayResponse        Json?     @map("gateway_response")
  salesforceRecordId     String?   @map("salesforce_record_id")
  errorMessage           String?   @map("error_message")
  recordedAt             DateTime? @map("recorded_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@map("sales_booking_card_payments")
}
